auto;">Status</button>\n      <button class="secondary settings-toggle" id="settingsToggleBtn" aria-label="Open settings" aria-controls="settingsPanel" aria-expanded="false">☰</button>\n    </div>\n  </header>\n\n  <div class="settings-scrim" id="settingsScrim" aria-hidden="true"></div>\n\n  <main class="shell">\n    <section class="card chat-card">\n      <div class="chat-head">\n        <div>\n          <div class="chat-title">Main Chat</div>\n          <div class="chat-subtitle">Run news, LOOKUP, SEEING, TARGETS, and normal chat from this main workspace.</div>\n        </div>\n        <button class="secondary" id="clearBtn" style="width:auto;">Clear</button>\n      </div>\n\n      <div class="tool-ribbon" aria-label="FZAstro quick tools">\n        <div class="lookup-combo" title="Object lookup">\n          <input id="lookupQuery" value="M31" aria-label="Object lookup" />\n          <button class="tool" id="lookupBtn">🔭 LOOKUP</button>\n        </div>\n        <button class="tool" id="dailyNewsBtn">📰 Daily News</button>\n        <button class="tool" id="seeingBtn">🌙 SEEING</button>\n        <button class="tool" id="targetsBtn">🎯 TARGETS</button>\n        <button class="tool" id="sitePlannerBtn">🗺 Site Planner</button>\n      </div>\n\n      <div class="messages" id="messages"></div>\n\n      <div class="composer">\n        <textarea id="prompt" placeholder="Ask the local model, or use a top tool button…"></textarea>\n        <div class="row">\n          <button id="sendBtn">Send</button>\n          <button class="secondary" id="stopHintBtn" title="Streaming stop will be added in a later patch." disabled>Stop</button>\n        </div>\n      </div>\n      <div class="statusbar" id="statusbar"></div>\n    </section>\n\n    <aside class="control-panel card" id="settingsPanel" aria-label="Web Companion settings">\n      <div class="panel-drawer-head">\n        <div>\n          <div class="section-title">Settings</div>\n          <div class="section-hint">Model, token, runtime, and access details.</div>\n        </div>\n        <button class="secondary drawer-close" id="settingsCloseBtn" aria-label="Close settings">×</button>\n      </div>\n      <div class="panel-section">\n        <div class="section-title">Model</div>\n        <div class="section-hint">Keep the working area clean. Advanced runtime details stay collapsed.</div>\n        <div class="grid">\n          <div>\n            <label for="modelSelect">Model</label>\n            <select id="modelSelect"></select>\n          </div>\n          <button class="secondary" id="refreshModelsBtn">Refresh models</button>\n          <div>\n            <label for="tokenInput">Web token, if LAN mode uses one</label>\n            <input id="tokenInput" placeholder="Token" type="password" />\n          </div>\n          <details>\n            <summary>Advanced runtime</summary>\n            <div class="details-body">\n              <div>\n                <label for="baseUrl">Runtime URL</label>\n                <input id="baseUrl" value="http://localhost:11434/v1" />\n              </div>\n              <div class="two grid">\n                <div>\n                  <label for="numPredict">Max tokens</label>\n                  <input id="numPredict" type="number" min="64" max="32768" value="4096" />\n                </div>\n                <div>\n                  <label for="temperature">Temperature</label>\n                  <input id="temperature" type="number" min="0" max="2" step="0.05" value="0.3" />\n                </div>\n              </div>\n            </div>\n          </details>\n        </div>\n      </div>\n\n      <div class="panel-section">\n        <div class="section-title">Current site</div>\n        <div class="section-hint">Used by SEEING and TARGETS. Open Site Planner to select from a map.</div>\n        <div class="site-summary" id="siteSummary">39.784080, -3.999020 · 660 m · Europe/Madrid</div>\n      </div>\n\n      <div class="panel-section">\n        <div class="section-title">Access</div>\n        <div class="section-hint">For iPad/Mac use the LAN URL shown by the desktop app.</div>\n        <div class="mini-note" id="accessNote">Local page loaded. Use LAN mode in the desktop app to open this from another device.</div>\n      </div>\n    </aside>\n  </main>\n\n  <div class="modal-backdrop" id="siteModal" role="dialog" aria-modal="true" aria-labelledby="siteModalTitle">\n    <div class="modal">\n      <div class="modal-head">\n        <div>\n          <div class="chat-title" id="siteModalTitle">Site Planner</div>\n          <div class="chat-subtitle">Click the map, use browser location, or type coordinates. Timezone is resolved automatically.</div>\n        </div>\n        <button class="secondary" id="siteCloseBtn" style="width:auto;">Close</button>\n      </div>\n      <div class="modal-body">\n        <div id="siteMap" class="site-map"></div>\n        <div class="grid">\n          <div class="two grid">\n            <div>\n              <label for="latInput">Latitude</label>\n              <input id="latInput" value="39.78408" />\n            </div>\n            <div>\n              <label for="lonInput">Longitude</label>\n              <input id="lonInput" value="-3.99902" />\n            </div>\n          </div>\n          <div class="two grid">\n            <div>\n              <label for="elevInput">Elevation m</label>\n              <input id="elevInput" value="660" />\n            </div>\n            <div>\n              <label for="tzInput">Timezone</label>\n              <input id="tzInput" value="Europe/Madrid" placeholder="Auto" />\n            </div>\n          </div>\n          <button id="useBrowserLocationBtn">Use this device location</button>\n          <button class="secondary" id="resolveTimezoneBtn">Resolve timezone</button>\n          <div class="mini-note" id="timezoneNote">Timezone: Europe/Madrid</div>\n        </div>\n      </div>\n      <div class="modal-foot">\n        <div class="mini-note">SEEING and TARGETS use this selected site automatically.</div>\n        <button id="siteApplyBtn" style="width:auto; min-width: 11rem;">Use selected site</button>\n      </div>\n    </div>\n  </div>\n\n  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>\n  <script>\n    const messagesEl = document.getElementById(\'messages\');\n    const statusbar = document.getElementById(\'statusbar\');\n    const topStatus = document.getElementById(\'topStatus\');\n    const modelSelect = document.getElementById(\'modelSelect\');\n    const baseUrl = document.getElementById(\'baseUrl\');\n    const tokenInput = document.getElementById(\'tokenInput\');\n    const promptEl = document.getElementById(\'prompt\');\n    const sendBtn = document.getElementById(\'sendBtn\');\n    const numPredict = document.getElementById(\'numPredict\');\n    const temperature = document.getElementById(\'temperature\');\n    const accessNote = document.getElementById(\'accessNote\');\n    const siteSummary = document.getElementById(\'siteSummary\');\n    const siteModal = document.getElementById(\'siteModal\');\n    const siteMapEl = document.getElementById(\'siteMap\');\n    const timezoneNote = document.getElementById(\'timezoneNote\');\n    const settingsToggleBtn = document.getElementById(\'settingsToggleBtn\');\n    const settingsCloseBtn = document.getElementById(\'settingsCloseBtn\');\n    const settingsScrim = document.getElementById(\'settingsScrim\');\n\n    let siteMap = null;\n    let siteMarker = null;\n    let lastSiteResolve = 0;\n\n    messagesEl.addEventListener(\'wheel\', event => {\n      // Keep mouse-wheel movement inside the transcript.\n      if (messagesEl.scrollHeight <= messagesEl.clientHeight) return;\n      const maxTop = messagesEl.scrollHeight - messagesEl.clientHeight;\n      const nextTop = Math.max(0, Math.min(maxTop, messagesEl.scrollTop + event.deltaY));\n      if (nextTop !== messagesEl.scrollTop) {\n        messagesEl.scrollTop = nextTop;\n        event.preventDefault();\n      }\n      event.stopPropagation();\n    }, { passive: false });\n\n    function setSettingsOpen(open) {\n      document.body.classList.toggle(\'settings-open\', open);\n      if (settingsToggleBtn) {\n        settingsToggleBtn.setAttribute(\'aria-expanded\', open ? \'true\' : \'false\');\n        settingsToggleBtn.setAttribute(\'aria-label\', open ? \'Close settings\' : \'Open settings\');\n      }\n    }\n\n    settingsToggleBtn?.addEventListener(\'click\', () => {\n      setSettingsOpen(!document.body.classList.contains(\'settings-open\'));\n    });\n    settingsCloseBtn?.addEventListener(\'click\', () => setSettingsOpen(false));\n    settingsScrim?.addEventListener(\'click\', () => setSettingsOpen(false));\n    document.addEventListener(\'keydown\', event => {\n      if (event.key === \'Escape\') setSettingsOpen(false);\n    });\n\n    tokenInput.value = localStorage.getItem(\'fzastro_web_token\') || \'\';\n    tokenInput.addEventListener(\'change\', () => {\n      localStorage.setItem(\'fzastro_web_token\', tokenInput.value.trim());\n      checkStatus();\n      refreshModels();\n    });\n\n    function headers(json = true) {\n      const h = {};\n      if (json) h[\'Content-Type\'] = \'application/json\';\n      const token = tokenInput.value.trim();\n      if (token) h[\'X-FZAstro-Token\'] = token;\n      return h;\n    }\n\n    function escapeHtml(text) {\n      return String(text ?? \'\').replace(/[&<>\'"]/g, ch => ({\n        \'&\': \'&amp;\', \'<\': \'&lt;\', \'>\': \'&gt;\', "\'": \'&#39;\', \'"\': \'&quot;\'\n      }[ch]));\n    }\n\n    function escapeAttr(text) { return escapeHtml(text).replace(/`/g, \'&#96;\'); }\n\n    function scrollChatToBottom() {\n      requestAnimationFrame(() => {\n        messagesEl.scrollTop = messagesEl.scrollHeight;\n      });\n    }\n\n    function setStatus(parts) {\n      statusbar.innerHTML = parts.map(p => `<span class="pill">${p}</span>`).join(\'\');\n    }\n\n    function setTop(text, cls = \'\') {\n      topStatus.className = `pill ${cls}`.trim();\n      topStatus.textContent = text;\n    }\n\n    function messageShell(role, title = \'\') {\n      const div = document.createElement(\'article\');\n      div.className = `msg ${role}`;\n      if (title) {\n        const meta = document.createElement(\'div\');\n        meta.className = \'msg-meta\';\n        meta.innerHTML = `<span>${escapeHtml(title)}</span><span>${new Date().toLocaleTimeString([], {hour: \'2-digit\', minute: \'2-digit\'})}</span>`;\n        div.appendChild(meta);\n      }\n      const body = document.createElement(\'div\');\n      body.className = \'msg-body\';\n      div.appendChild(body);\n      messagesEl.appendChild(div);\n      scrollChatToBottom();\n      return { div, body };\n    }\n\n    function addMessage(role, text, options = {}) {\n      const { body, div } = messageShell(role, options.title || \'\');\n      if (options.html) {\n        body.classList.add(\'html\');\n        body.innerHTML = text || \'\';\n      } else {\n        body.textContent = text || \'\';\n      }\n      if (options.images && options.images.length) {\n        const strip = document.createElement(\'div\');\n        strip.className = \'image-strip\';\n        for (const src of options.images) {\n          const img = document.createElement(\'img\');\n          img.loading = \'lazy\';\n          img.src = src;\n          img.alt = options.title || \'FZAstro image result\';\n          img.addEventListener(\'load\', scrollChatToBottom, { once: true });\n          strip.appendChild(img);\n        }\n        div.appendChild(strip);\n      }\n      scrollChatToBottom();\n      return body;\n    }\n\n    function sourceHost(url) {\n      try {\n        const host = new URL(url).hostname.replace(/^www\\./, \'\');\n        return host || \'Source\';\n      } catch (_) {\n        return \'Source\';\n      }\n    }\n\n    function sourceDisplayName(source, id) {\n      const name = String(source?.name || source?.source_name || \'\').trim();\n      if (name && name.toLowerCase() !== \'source\') return name;\n      const host = sourceHost(source?.url || \'\');\n      if (host && host !== \'Source\') return host;\n      return \'Source\';\n    }\n\n    function markdownToHtml(markdown, sources = {}) {\n      const lines = String(markdown || \'\').split(/\\r?\\n/);\n      let html = \'\';\n      let inList = false;\n      const closeList = () => { if (inList) { html += \'</ul>\'; inList = false; } };\n      const inline = (text) => escapeHtml(text).replace(/\\[(NEWS_\\d{4,})\\]/g, (m, id) => {\n        const source = sources[id];\n        if (source && source.url) {\n          const label = sourceDisplayName(source, id);\n          const tooltip = [label, source.title || \'\'].filter(Boolean).join(\' · \');\n          return `<a class="news-source" href="${escapeAttr(source.url)}" title="${escapeAttr(tooltip)}" target="_blank" rel="noopener">${escapeHtml(label)}</a>`;\n        }\n        return \'<span class="news-source">Source</span>\';\n      });\n\n      for (const raw of lines) {\n        const line = raw.trim();\n        if (!line) { closeList(); continue; }\n        if (line.startsWith(\'# \')) { closeList(); html += `<h1>${inline(line.slice(2))}</h1>`; continue; }\n        if (line.startsWith(\'## \')) { closeList(); html += `<h2>${inline(line.slice(3))}</h2>`; continue; }\n        if (line.startsWith(\'### \')) { closeList(); html += `<h3>${inline(line.slice(4))}</h3>`; continue; }\n        if (line.startsWith(\'- \')) {\n          if (!inList) { html += \'<ul>\'; inList = true; }\n          html += `<li>${inline(line.slice(2))}</li>`;\n          continue;\n        }\n        closeList();\n        html += `<p>${inline(line)}</p>`;\n      }\n      closeList();\n      return html || \'<p>No content returned.</p>\';\n    }\n\n    function looksLikeHtml(text) {\n      return /^\\s*<(div|table|section|article|h\\d|p|ul|ol)\\b/i.test(String(text || \'\'));\n    }\n\n    function assetTokenQuery() {\n      const token = tokenInput.value.trim();\n      return token ? `&fzastro_token=${encodeURIComponent(token)}` : \'\';\n    }\n\n    function fileUrls(files) {\n      const stamp = Date.now();\n      return (files || [])\n        .filter(path => /\\.(png|jpe?g|webp|gif|bmp|svg)$/i.test(String(path)))\n        .map(path => `/api/assets/file?path=${encodeURIComponent(path)}${assetTokenQuery()}&v=${stamp}`);\n    }\n\n    async function apiJson(url, options = {}) {\n      const response = await fetch(url, options);\n      const data = await response.json().catch(() => ({}));\n      if (!response.ok) throw new Error(data.detail || data.error || response.statusText);\n      return data;\n    }\n\n    async function checkStatus() {\n      try {\n        const data = await apiJson(\'/api/status\', { headers: headers(false) });\n        setTop(data.ollama_available ? \'Ollama online\' : \'Ollama offline\', data.ollama_available ? \'good\' : \'warn\');\n        setStatus([\n          data.ollama_available ? \'<span class="good">Ollama online</span>\' : \'<span class="warn">Ollama offline</span>\',\n          `Model: ${escapeHtml(data.default_model)}`,\n          data.auth_required ? \'Token required\' : \'No token\',\n          data.lan_enabled ? \'LAN mode\' : \'Local mode\'\n        ]);\n        if (data.base_url) baseUrl.value = data.base_url;\n        accessNote.textContent = data.lan_enabled ? \'LAN mode is enabled. Open this page from your iPad/Mac using the PC LAN URL.\' : \'Local mode is enabled. Start LAN / iPad Mode from the desktop app for mobile access.\';\n      } catch (err) {\n        setTop(\'Token needed\', \'warn\');\n        setStatus([`<span class="bad">Status: ${escapeHtml(err.message)}</span>`]);\n      }\n    }\n\n    async function refreshModels() {\n      modelSelect.innerHTML = \'<option>Loading…</option>\';\n      try {\n        const url = `/api/models?base_url=${encodeURIComponent(baseUrl.value.trim())}`;\n        const data = await apiJson(url, { headers: headers(false) });\n        modelSelect.innerHTML = \'\';\n        for (const model of data.models || []) {\n          const opt = document.createElement(\'option\');\n          opt.value = model;\n          opt.textContent = model;\n          modelSelect.appendChild(opt);\n        }\n        setStatus([`${(data.models || []).length} model(s) loaded`]);\n      } catch (err) {\n        modelSelect.innerHTML = \'<option>qwen3:32b</option>\';\n        setStatus([`<span class="bad">Model refresh: ${escapeHtml(err.message)}</span>`]);\n      }\n    }\n\n    async function sendChat() {\n      const prompt = promptEl.value.trim();\n      if (!prompt) return;\n      promptEl.value = \'\';\n      addMessage(\'user\', prompt, { title: \'You\' });\n      const assistant = addMessage(\'assistant\', \'\', { title: modelSelect.value || \'Assistant\' });\n      sendBtn.disabled = true;\n      setStatus([\'Generating…\']);\n\n      try {\n        const response = await fetch(\'/api/chat/stream\', {\n          method: \'POST\',\n          headers: headers(true),\n          body: JSON.stringify({\n            prompt,\n            model: modelSelect.value || \'qwen3:32b\',\n            base_url: baseUrl.value.trim(),\n            num_predict: Number(numPredict.value || 4096),\n            temperature: Number(temperature.value || 0.3),\n            think_enabled: true,\n            stream_reasoning: false\n          })\n        });\n\n        if (!response.ok) {\n          const data = await response.json().catch(() => ({}));\n          throw new Error(data.detail || data.error || response.statusText);\n        }\n\n        const reader = response.body.getReader();\n        const decoder = new TextDecoder();\n        let buffer = \'\';\n        while (true) {\n          const { value, done } = await reader.read();\n          if (done) break;\n          buffer += decoder.decode(value, { stream: true });\n          const events = buffer.split(\'\\n\\n\');\n          buffer = events.pop();\n          for (const block of events) {\n            const lines = block.split(\'\\n\');\n            const event = (lines.find(l => l.startsWith(\'event:\')) || \'\').slice(6).trim();\n            const dataLine = (lines.find(l => l.startsWith(\'data:\')) || \'\').slice(5).trim();\n            if (!dataLine) continue;\n            const data = JSON.parse(dataLine);\n            if (event === \'token\') {\n              assistant.textContent += data.text || \'\';\n              scrollChatToBottom();\n            } else if (event === \'error\') {\n              assistant.textContent += `\\n\\n[Error] ${data.message}`;\n              setStatus([`<span class="bad">${escapeHtml(data.message)}</span>`]);\n            } else if (event === \'done\') {\n              setStatus([`Done`, `Model: ${escapeHtml(data.model)}`, `Reasoning hidden: ${data.reasoning_chars || 0} chars`]);\n            } else if (event === \'status\') {\n              setStatus([escapeHtml(data.message || \'Starting\')]);\n            }\n          }\n        }\n      } catch (err) {\n        assistant.textContent += `\\n\\n[Error] ${err.message}`;\n        setStatus([`<span class="bad">Chat: ${escapeHtml(err.message)}</span>`]);\n      } finally {\n        sendBtn.disabled = false;\n      }\n    }\n\n    function numericValue(id) { return Number(document.getElementById(id).value); }\n\n    function updateSiteSummary() {\n      const lat = numericValue(\'latInput\');\n      const lon = numericValue(\'lonInput\');\n      const elev = numericValue(\'elevInput\');\n      const tz = document.getElementById(\'tzInput\').value.trim() || \'Auto timezone\';\n      siteSummary.textContent = `${lat.toFixed(6)}, ${lon.toFixed(6)} · ${Number.isFinite(elev) ? elev : 0} m · ${tz}`;\n      timezoneNote.textContent = `Timezone: ${tz}`;\n    }\n\n    function locationPayload() {\n      return {\n        lat: numericValue(\'latInput\'),\n        lon: numericValue(\'lonInput\'),\n        elev: numericValue(\'elevInput\'),\n        tz: document.getElementById(\'tzInput\').value.trim() || null\n      };\n    }\n\n    async function resolveTimezoneFromServer(force = false) {\n      const now = Date.now();\n      if (!force && now - lastSiteResolve < 450) return;\n      lastSiteResolve = now;\n      try {\n        const payload = locationPayload();\n        const data = await apiJson(\'/api/location/resolve\', {\n          method: \'POST\',\n          headers: headers(true),\n          body: JSON.stringify(payload)\n        });\n        if (data.timezone) document.getElementById(\'tzInput\').value = data.timezone;\n        timezoneNote.textContent = data.local_time ? `Timezone: ${data.timezone} · Local: ${data.local_time}` : `Timezone: ${data.timezone || \'UTC\'}`;\n        updateSiteSummary();\n      } catch (err) {\n        const browserTz = Intl.DateTimeFormat().resolvedOptions().timeZone || \'UTC\';\n        if (!document.getElementById(\'tzInput\').value.trim()) document.getElementById(\'tzInput\').value = browserTz;\n        timezoneNote.textContent = `Timezone fallback: ${document.getElementById(\'tzInput\').value || browserTz}`;\n        updateSiteSummary();\n      }\n    }\n\n    async function ensureTimezone() {\n      if (!document.getElementById(\'tzInput\').value.trim()) {\n        await resolveTimezoneFromServer(true);\n      }\n      return locationPayload();\n    }\n\n    function setSitePosition(lat, lon, elev = null, shouldResolve = true) {\n      document.getElementById(\'latInput\').value = Number(lat).toFixed(6);\n      document.getElementById(\'lonInput\').value = Number(lon).toFixed(6);\n      if (elev !== null && elev !== undefined && Number.isFinite(Number(elev))) {\n        document.getElementById(\'elevInput\').value = Number(elev).toFixed(0);\n      }\n      if (siteMarker && siteMap) {\n        const pos = [Number(lat), Number(lon)];\n        siteMarker.setLatLng(pos);\n        siteMap.setView(pos, Math.max(siteMap.getZoom() || 5, 5), { animate: false });\n      }\n      updateSiteSummary();\n      if (shouldResolve) resolveTimezoneFromServer(true);\n    }\n\n    function refreshSiteMapLayout() {\n      if (!siteMap) return;\n      const lat = numericValue(\'latInput\');\n      const lon = numericValue(\'lonInput\');\n      siteMap.invalidateSize({ animate: false });\n      siteMap.setView([lat, lon], Math.max(siteMap.getZoom() || 5, 5), { animate: false });\n      if (siteMarker) siteMarker.setLatLng([lat, lon]);\n    }\n\n    function openSitePlanner() {\n      siteModal.classList.add(\'open\');\n      initMapIfNeeded();\n      updateSiteSummary();\n      requestAnimationFrame(refreshSiteMapLayout);\n      setTimeout(refreshSiteMapLayout, 180);\n      setTimeout(refreshSiteMapLayout, 520);\n    }\n\n    function closeSitePlanner() { siteModal.classList.remove(\'open\'); }\n\n    function initFallbackMap() {\n      siteMapEl.innerHTML = \'<div class="fallback-map" id="fallbackMap"></div>\';\n      const fallback = document.getElementById(\'fallbackMap\');\n      fallback.addEventListener(\'click\', event => {\n        const rect = fallback.getBoundingClientRect();\n        const x = Math.max(0, Math.min(1, (event.clientX - rect.left) / rect.width));\n        const y = Math.max(0, Math.min(1, (event.clientY - rect.top) / rect.height));\n        const lon = x * 360 - 180;\n        const lat = 90 - y * 180;\n        setSitePosition(lat, lon);\n      });\n    }\n\n    function initMapIfNeeded() {\n      if (siteMap || siteMapEl.dataset.fallbackReady) return;\n      const lat = numericValue(\'latInput\');\n      const lon = numericValue(\'lonInput\');\n      if (!window.L) {\n        siteMapEl.dataset.fallbackReady = \'1\';\n        initFallbackMap();\n        return;\n      }\n      siteMap = L.map(\'siteMap\', {\n        worldCopyJump: true,\n        zoomControl: true,\n        preferCanvas: true\n      }).setView([lat, lon], 5);\n      L.tileLayer(\'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png\', {\n        maxZoom: 19,\n        minZoom: 2,\n        attribution: \'&copy; OpenStreetMap contributors\',\n        updateWhenIdle: false,\n        keepBuffer: 4\n      }).addTo(siteMap);\n      siteMarker = L.marker([lat, lon], { draggable: true, icon: L.divIcon({ className: \'fz-site-marker\', iconSize: [20, 20], iconAnchor: [10, 10] }) }).addTo(siteMap);\n      siteMarker.on(\'dragend\', () => {\n        const pos = siteMarker.getLatLng();\n        setSitePosition(pos.lat, pos.lng);\n      });\n      siteMap.on(\'click\', event => setSitePosition(event.latlng.lat, event.latlng.lng));\n      if (window.ResizeObserver) {\n        const observer = new ResizeObserver(() => refreshSiteMapLayout());\n        observer.observe(siteMapEl);\n      }\n    }\n\n    async function runAstro(endpoint, payload, title) {\n      const pending = addMessage(\'assistant\', \'Running…\', { title });\n      try {\n        const data = await apiJson(endpoint, {\n          method: \'POST\',\n          headers: headers(true),\n          body: JSON.stringify(payload)\n        });\n        const images = fileUrls(data.files || []);\n        pending.classList.add(\'html\');\n        pending.innerHTML = looksLikeHtml(data.text) ? data.text : markdownToHtml(data.text || JSON.stringify(data, null, 2));\n        if (images.length) {\n          const strip = document.createElement(\'div\');\n          strip.className = \'image-strip\';\n          for (const src of images) {\n            const img = document.createElement(\'img\');\n            img.loading = \'lazy\';\n            img.src = src;\n            img.alt = title;\n            img.addEventListener(\'load\', scrollChatToBottom, { once: true });\n            strip.appendChild(img);\n          }\n          pending.parentElement.appendChild(strip);\n        }\n        setStatus([`${escapeHtml(title)} done`]);\n        scrollChatToBottom();\n      } catch (err) {\n        pending.textContent = `Error: ${err.message}`;\n        setStatus([`<span class="bad">${escapeHtml(title)}: ${escapeHtml(err.message)}</span>`]);\n      }\n    }\n\n    async function runDailyNews(refresh = false) {\n      const pending = addMessage(\'assistant\', refresh ? \'Refreshing Daily News…\' : \'Fetching Daily News…\', { title: \'Daily News Brief\' });\n      try {\n        const data = await apiJson(`/api/news/daily?refresh=${refresh ? \'true\' : \'false\'}`, { headers: headers(false) });\n        pending.classList.add(\'html\');\n        pending.innerHTML = markdownToHtml(data.brief || \'\', data.sources || {});\n        const count = Object.keys(data.sources || {}).length;\n        setStatus([`Daily News ready`, `${count} source link(s)`]);\n        scrollChatToBottom();\n      } catch (err) {\n        pending.textContent = `Daily News error: ${err.message}`;\n        setStatus([`<span class="bad">Daily News: ${escapeHtml(err.message)}</span>`]);\n      }\n    }\n\n    document.getElementById(\'refreshModelsBtn\').addEventListener(\'click\', refreshModels);\n    document.getElementById(\'checkStatusBtn\').addEventListener(\'click\', checkStatus);\n    document.getElementById(\'clearBtn\').addEventListener(\'click\', () => { messagesEl.innerHTML = \'\'; });\n    sendBtn.addEventListener(\'click\', sendChat);\n    promptEl.addEventListener(\'keydown\', event => {\n      if (event.key === \'Enter\' && (event.ctrlKey || event.metaKey)) sendChat();\n    });\n\n    document.getElementById(\'dailyNewsBtn\').addEventListener(\'click\', () => runDailyNews(false));\n    document.getElementById(\'lookupBtn\').addEventListener(\'click\', () => runAstro(\'/api/astro/lookup\', {\n      query: document.getElementById(\'lookupQuery\').value.trim() || \'M31\',\n      with_image: true,\n      fov_deg: 2.337\n    }, \'LOOKUP\'));\n    document.getElementById(\'seeingBtn\').addEventListener(\'click\', async () => runAstro(\'/api/astr